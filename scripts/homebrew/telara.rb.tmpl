# This file is a template — GoReleaser replaces {{.Version}} and checksum values.
# The actual formula lives in github.com/Telara-Labs/homebrew-tap
class Telara < Formula
  desc "Telara CLI — manage your MCP configurations"
  homepage "https://telara.dev"
  version "{{.Version}}"

  on_macos do
    on_arm do
      url "https://get.telara.dev/download/v{{.Version}}/telara_{{.Version}}_darwin_arm64.tar.gz"
      sha256 "{{.Sha256DarwinArm64}}"
    end
    on_intel do
      url "https://get.telara.dev/download/v{{.Version}}/telara_{{.Version}}_darwin_amd64.tar.gz"
      sha256 "{{.Sha256DarwinAmd64}}"
    end
  end

  on_linux do
    on_arm do
      url "https://get.telara.dev/download/v{{.Version}}/telara_{{.Version}}_linux_arm64.tar.gz"
      sha256 "{{.Sha256LinuxArm64}}"
    end
    on_intel do
      url "https://get.telara.dev/download/v{{.Version}}/telara_{{.Version}}_linux_amd64.tar.gz"
      sha256 "{{.Sha256LinuxAmd64}}"
    end
  end

  def install
    bin.install "telara"
  end

  test do
    system "#{bin}/telara", "version"
  end
end
